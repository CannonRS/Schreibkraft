<Project>
  <PropertyGroup>
    <LangVersion>preview</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Deterministic>true</Deterministic>
    <Authors>Schreibkraft</Authors>
    <Product>Schreibkraft</Product>

    <!-- Zentrale Versionsnummer für App-Assemblies (AppVersion).
         An einer Stelle ändern; Projekte erben über $(AppVersion).
         Format: Major.Minor.Patch (3-stellig). -->
    <AppVersion>1.3.0</AppVersion>
    <Version>$(AppVersion)</Version>
    <AssemblyVersion>$(AppVersion).0</AssemblyVersion>
    <FileVersion>$(AppVersion).0</FileVersion>
    <!-- Ohne dieses Flag hängt das .NET-SDK die Git-Commit-ID an die InformationalVersion
         (SemVer-Metadaten nach „+“) — erscheint dann in Fenstertitel und ProductVersion. -->
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
  </PropertyGroup>
</Project>
